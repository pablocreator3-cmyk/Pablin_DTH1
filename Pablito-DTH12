-- 3. LÓGICA DE FARM QUE SÍ SIRVE
local function createToggle(text, pos, callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Text = "[ OFF ] " .. text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.SourceSansBold
    
    local enabled = false
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        btn.Text = enabled and "[ ON ] " .. text or "[ OFF ] " .. text
        btn.TextColor3 = enabled and Color3.new(0,1,0) or Color3.new(1,1,1)
        callback(enabled)
    end)
end

-- FUNCIÓN MAESTRA DE FUERZA
local autoLift = false
createToggle("AUTO LIFT (TODAS LAS PESAS)", 50, function(val) autoLift = val end)

task.spawn(function()
    while true do
        if autoLift then
            local char = player.Character
            if char then
                -- Busca CUALQUIER herramienta que sea una pesa
                local tool = player.Backpack:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
                
                if tool then
                    -- La equipa automáticamente
                    if tool.Parent == player.Backpack then
                        tool.Parent = char
                    end
                    
                    -- DISPARO DOBLE (Para asegurar que el servidor lo reciba)
                    if remote then
                        -- Intento 1: Evento estándar
                        remote:FireServer("liftWeight", tool.Name)
                        -- Intento 2: Simulacro de click
                        tool:Activate()
                    end
                end
            end
        end
        task.wait(0.01) -- Velocidad extrema (Si te da lag, sube a 0.1)
    end
end)

