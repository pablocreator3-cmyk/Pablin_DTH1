--[[
    SCRIPT: DTH HUB - ANIME FIGHTING SIMULATOR
    INTERFAZ: ELERIUM / VENYX STYLE
]]

local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Steventhebest/Venyx-UI-Library/main/Source"))()
local venyx = library.new("DTH HUB | Anime Fighting", 5013109572)

-- Configuración de Páginas
local page = venyx:addPage("Farm", 5012544693)
local section = page:addSection("Auto Entrenamiento")

-- Variables de Control
getgenv().autoStrength = false
getgenv().autoDurability = false
getgenv().autoChakra = false
getgenv().autoSword = false
getgenv().autoAgility = false

-- SECCIÓN: FUERZA
section:addToggle("Auto Strength", false, function(state)
    getgenv().autoStrength = state
    spawn(function()
        while getgenv().autoStrength do
            game:GetService("ReplicatedStorage").RSPackage.Events.StatUpdate:FireServer("Attack", "Strength")
            task.wait(0.1)
        end
    end)
end)

-- SECCIÓN: DURABILIDAD
section:addToggle("Auto Durability", false, function(state)
    getgenv().autoDurability = state
    spawn(function()
        while getgenv().autoDurability do
            game:GetService("ReplicatedStorage").RSPackage.Events.StatUpdate:FireServer("Attack", "Durability")
            task.wait(0.1)
        end
    end)
end)

-- SECCIÓN: ESPADA (AUTO CLICKER)
section:addToggle("Auto Sword", false, function(state)
    getgenv().autoSword = state
    spawn(function()
        while getgenv().autoSword do
            game:GetService("ReplicatedStorage").RSPackage.Events.StatUpdate:FireServer("Attack", "Sword")
            -- Intenta activar la herramienta si está equipada
            local tool = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
            task.wait(0.1)
        end
    end)
end)

-- SECCIÓN: CHAKRA
section:addToggle("Auto Chakra", false, function(state)
    getgenv().autoChakra = state
    spawn(function()
        while getgenv().autoChakra do
            game:GetService("ReplicatedStorage").RSPackage.Events.StatUpdate:FireServer("Attack", "Chakra")
            task.wait(0.1)
        end
    end)
end)

-- SECCIÓN: AGILIDAD (NUEVO)
section:addToggle("Auto Agility", false, function(state)
    getgenv().autoAgility = state
    spawn(function()
        while getgenv().autoAgility do
            game:GetService("ReplicatedStorage").RSPackage.Events.StatUpdate:FireServer("Attack", "Agility")
            task.wait(0.1)
        end
    end)
end)

-- PÁGINA DE CONFIGURACIÓN
local settingsPage = venyx:addPage("Config", 5012544693)
local settingsSection = settingsPage:addSection("Interfaz")

settingsSection:addKeybind("Ocultar/Mostrar", Enum.KeyCode.RightControl, function()
    venyx:toggle()
end)

settingsSection:addColorPicker("Color de Tema", Color3.fromRGB(0, 102, 255), function(color)
    venyx:setTheme("Primary", color)
end)

-- Seleccionar la primera página al cargar
venyx:SelectPage(venyx.pages[1], true)
